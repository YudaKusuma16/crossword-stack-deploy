# ===============================
# Root .gitignore for Crossword Stack
# ===============================



# Environment Variables (IMPORTANT!)
backend/.env
frontend/.env
.env
.env.local
.env.production

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build Output
dist/
frontend/dist/
.build/
.vercel/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.claude/

# Testing
coverage/
.nyc_output/
*.lcov

# Misc
*.pem
.cache/
.parcel-cache/
.vite/
.turbo/

# Temporary server folder
server/

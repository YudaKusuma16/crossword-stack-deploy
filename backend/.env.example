# ====================================
# Crossword Stack Backend - Environment Variables
# ====================================
# Copy this file to .env for local development
# For Render deployment, set these in Render Dashboard

# ------------------------------------
# Server Configuration
# ------------------------------------
NODE_ENV=production
PORT=3001

# ------------------------------------
# Database Configuration (Clever Cloud MySQL)
# ------------------------------------
# Get these values from Clever Cloud Console → Your MySQL Instance
# Navigate: Configuration → Variables (or use the connection string)
DB_HOST=your-mysql-host.clever-cloud.com
DB_PORT=3306
DB_USER=your_clever_cloud_user
DB_PASSWORD=your_clever_cloud_password
DB_NAME=your_clever_cloud_database_name
DB_SSL=true

# ------------------------------------
# JWT Authentication
# ------------------------------------
# Generate a strong random string for production
# Use: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ------------------------------------
# CORS Configuration
# ------------------------------------
# Update with your deployed Vercel frontend URL
# After deploying frontend to Vercel, update this value
CORS_ORIGIN=https://your-frontend.vercel.app

# ------------------------------------
# Deployment Notes
# ------------------------------------
# For Render deployment:
# 1. Create MySQL instance on Clever Cloud first
# 2. Copy database credentials to Render environment variables
# 3. Deploy backend to Render
# 4. Copy Render URL and use it in Vercel frontend
# 5. Update CORS_ORIGIN with Vercel frontend URL

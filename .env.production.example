# ====================================
# Production Environment Variables Template
# ====================================
# This file is a reference for ALL required environment variables
# Copy relevant sections to each platform's environment settings

# ------------------------------------
# Backend (Render)
# ------------------------------------
NODE_ENV=production
PORT=3001

# Database (Clever Cloud MySQL)
DB_HOST=xxxxx.mysql.clever-cloud.com
DB_PORT=3306
DB_USER=xxxxx
DB_PASSWORD=xxxxx
DB_NAME=xxxxx
DB_SSL=true

# JWT Authentication
JWT_SECRET=<generate_with: node scripts/generate-jwt-secret.js>
JWT_EXPIRES_IN=7d

# CORS (after frontend deployment)
CORS_ORIGIN=https://your-frontend.vercel.app

# ------------------------------------
# Frontend (Vercel)
# ------------------------------------
VITE_API_URL=https://your-backend.onrender.com

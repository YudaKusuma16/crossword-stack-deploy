# ====================================
# Crossword Stack Frontend - Environment Variables
# ====================================
# Copy this file to .env for local development
# For Vercel deployment, set VITE_API_URL in Vercel Dashboard

# ------------------------------------
# API Configuration
# ------------------------------------
# For local development with local backend:
VITE_API_URL=http://localhost:3001

# For local development with deployed backend (Render):
# VITE_API_URL=https://your-backend.onrender.com

# For production deployment on Vercel:
# Set this in Vercel Dashboard → Environment Variables
# After deploying backend to Render, update with your Render URL
# VITE_API_URL=https://your-backend.onrender.com

# ------------------------------------
# Deployment Order
# ------------------------------------
# 1. Deploy MySQL to Clever Cloud → get DB credentials
# 2. Deploy Backend to Render → get Backend URL
# 3. Deploy Frontend to Vercel → set VITE_API_URL to Render URL
# 4. Update Backend CORS_ORIGIN with Vercel URL
